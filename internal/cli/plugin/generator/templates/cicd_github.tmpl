name: Deploy Plugins

on:
  push:
    tags:
      - 'v*'

permissions:
  contents: write

jobs:
  detect_plugins:
    runs-on: ubuntu-latest
    if: startsWith(github.ref, 'refs/tags/v')
    outputs:
      plugins: ${{ steps.set_plugins.outputs.plugins }}
      version: ${{ steps.version.outputs.version }}
    steps:
      - uses: actions/checkout@v4
      - name: Install dependencies
        run: sudo apt-get update && sudo apt-get install -y jq
      - name: Extract version from tag
        id: version
        run: |
          TAG=${GITHUB_REF#refs/tags/}
          case "$TAG" in
            v*)
              PLUGIN_VERSION=${TAG#v}
              ;;
            *)
              echo "Неверный формат тега: $TAG (ожидается v{version})"
              exit 1
              ;;
          esac
          echo "version=$PLUGIN_VERSION" >> $GITHUB_OUTPUT
      - name: Detect plugins
        id: set_plugins
        run: |
          PLUGINS=$(find plugins -mindepth 1 -maxdepth 1 -type d -exec basename {} \; | sort)
          JSON_PLUGINS=$(echo "$PLUGINS" | jq -R -s -c 'split("\n") | map(select(length > 0))')
          echo "plugins=$JSON_PLUGINS" >> $GITHUB_OUTPUT

  build_all:
    needs: detect_plugins
    runs-on: ubuntu-latest
    if: startsWith(github.ref, 'refs/tags/v')
    strategy:
      matrix:
        plugin: ${{ fromJSON(needs.detect_plugins.outputs.plugins) }}
    steps:
      - uses: actions/checkout@v4

      - name: Set up Go
        uses: actions/setup-go@v5
        with:
          go-version-file: go.mod

      - name: Install dependencies
        run: sudo apt-get update && sudo apt-get install -y jq

      - name: Build plugin
        env:
          PLUGIN_DIR: ${{ matrix.plugin }}
          PLUGIN_VERSION: ${{ needs.detect_plugins.outputs.version }}
        run: |
          PLUGIN_DIR_PATH="plugins/$PLUGIN_DIR"
          mkdir -p dist

          cd "$PLUGIN_DIR_PATH"
          TEMP_MANIFEST="../../dist/temp_${PLUGIN_DIR}.json"
          if ! go run -tags pluginInfo . "$TEMP_MANIFEST" 2>&1; then
            echo "ОШИБКА: не удалось сгенерировать манифест для $PLUGIN_DIR"
            exit 1
          fi

          if [ ! -f "$TEMP_MANIFEST" ]; then
            echo "ОШИБКА: файл манифеста не создан для $PLUGIN_DIR"
            exit 1
          fi

          PLUGIN_NAME=$(jq -r '.name' "$TEMP_MANIFEST")
          if [ -z "$PLUGIN_NAME" ] || [ "$PLUGIN_NAME" = "null" ]; then
            echo "ОШИБКА: Имя плагина не найдено в сгенерированном манифесте для $PLUGIN_DIR"
            exit 1
          fi

          jq --arg version "$PLUGIN_VERSION" '.version = $version' "$TEMP_MANIFEST" > "../../dist/$PLUGIN_NAME.json"
          if [ "$PLUGIN_NAME" != "$PLUGIN_DIR" ]; then
            cp "../../dist/$PLUGIN_NAME.json" "../../dist/$PLUGIN_DIR.json"
          fi
          rm -f "$TEMP_MANIFEST"

          echo "Building plugin: $PLUGIN_NAME (directory: $PLUGIN_DIR)"
          cd ../..
          GOOS=wasip1 GOARCH=wasm go build -o "$PLUGIN_DIR_PATH/$PLUGIN_NAME.tgp" -buildmode=c-shared "./$PLUGIN_DIR_PATH"

          gzip -9 -c "$PLUGIN_DIR_PATH/$PLUGIN_NAME.tgp" > "$PLUGIN_DIR_PATH/$PLUGIN_NAME.tgp.tmp" && mv "$PLUGIN_DIR_PATH/$PLUGIN_NAME.tgp.tmp" "$PLUGIN_DIR_PATH/$PLUGIN_NAME.tgp"

      - name: Upload artifacts
        uses: actions/upload-artifact@v4
        with:
          name: ${{ matrix.plugin }}-artifacts
          path: |
            plugins/${{ matrix.plugin }}/*.tgp
            dist/${{ matrix.plugin }}.json

  deploy_all:
    needs: [detect_plugins, build_all]
    runs-on: ubuntu-latest
    if: startsWith(github.ref, 'refs/tags/v')
    steps:
      - uses: actions/checkout@v4

      - name: Install dependencies
        run: sudo apt-get update && sudo apt-get install -y jq wget
      - name: Install yq
        # Ожидается mikefarah/yq (yq-go). Другой yq (например kislyuk) имеет иной синтаксис и ломает слияние манифеста.
        run: |
          sudo wget -qO /usr/local/bin/yq https://github.com/mikefarah/yq/releases/download/v4.44.1/yq_linux_amd64
          sudo chmod +x /usr/local/bin/yq
          yq --version

      - name: Download all artifacts
        uses: actions/download-artifact@v4
        with:
          path: artifacts/

      - name: Prepare release files
        id: prepare
        env:
          PLUGINS_JSON: ${{ needs.detect_plugins.outputs.plugins }}
          VERSION: ${{ needs.detect_plugins.outputs.version }}
          REPO_URL: https://github.com/${{ github.repository }}
        run: |
          mkdir -p "release"

          echo "version: '$VERSION'" > release/manifest.generated.yml
          echo "" >> release/manifest.generated.yml
          echo "packages:" >> release/manifest.generated.yml

          RELEASE_TAG="v$VERSION"
          FIRST_PACKAGE=true

          for PLUGIN_DIR in $(echo "$PLUGINS_JSON" | jq -r '.[]'); do
            ARTIFACT_DIR="artifacts/$PLUGIN_DIR-artifacts"
            PLUGIN_JSON_ARTIFACT="$ARTIFACT_DIR/dist/$PLUGIN_DIR.json"
            if [ ! -f "$PLUGIN_JSON_ARTIFACT" ]; then
              echo "ОШИБКА: JSON манифест не найден в артефактах для плагина $PLUGIN_DIR по пути $PLUGIN_JSON_ARTIFACT" >&2
              exit 1
            fi

            PLUGIN_NAME=$(jq -r '.name' "$PLUGIN_JSON_ARTIFACT")
            if [ -z "$PLUGIN_NAME" ] || [ "$PLUGIN_NAME" = "null" ]; then
              echo "ОШИБКА: Имя плагина не найдено в манифесте для $PLUGIN_DIR" >&2
              exit 1
            fi

            PLUGIN_DESCR=$(jq -r '.description // ""' "$PLUGIN_JSON_ARTIFACT")
            PLUGIN_DEPS=$(jq -r '.dependencies // []' "$PLUGIN_JSON_ARTIFACT")

            TGP_FILE="$ARTIFACT_DIR/plugins/$PLUGIN_DIR/$PLUGIN_NAME.tgp"
            if [ ! -f "$TGP_FILE" ]; then
              echo "ОШИБКА: Файл .tgp не найден для плагина $PLUGIN_NAME по пути $TGP_FILE" >&2
              exit 1
            fi

            DST="release/$PLUGIN_NAME.tgp"
            cp "$TGP_FILE" "$DST"
            echo "$DST" >> release_files.txt

            _CHECKSUM=$(sha256sum "$TGP_FILE" | awk '{print $1}')
            _URL="$REPO_URL/releases/download/$RELEASE_TAG/$PLUGIN_NAME.tgp"
            _DEST="plugins/$PLUGIN_DIR/$VERSION/$PLUGIN_NAME.tgp"

            if [ "$FIRST_PACKAGE" = "true" ]; then
              FIRST_PACKAGE=false
            else
              echo "" >> release/manifest.generated.yml
            fi

            echo "  - name: '$PLUGIN_NAME'" >> release/manifest.generated.yml
            if [ -n "$PLUGIN_DESCR" ] && [ "$PLUGIN_DESCR" != "null" ]; then
              echo "    descr: '$PLUGIN_DESCR'" >> release/manifest.generated.yml
            fi
            if [ "$PLUGIN_DEPS" != "[]" ] && [ "$PLUGIN_DEPS" != "null" ]; then
              echo "    dependencies:" >> release/manifest.generated.yml
              echo "$PLUGIN_DEPS" | jq -r '.[]' | while IFS= read -r dep; do
                if [ -n "$dep" ]; then
                  echo "      - '$dep'" >> release/manifest.generated.yml
                fi
              done
            fi
            echo "    downloads:" >> release/manifest.generated.yml
            echo "      - url: '$_URL'" >> release/manifest.generated.yml
            echo "    files:" >> release/manifest.generated.yml
            echo "      - file: '$PLUGIN_NAME.tgp'" >> release/manifest.generated.yml
            echo "        destination: '$_DEST'" >> release/manifest.generated.yml
            echo "        checksum: 'sha256:$_CHECKSUM'" >> release/manifest.generated.yml
          done

          if [ -f "manifest.overrides.yml" ]; then
            TMP_GEN=$(mktemp)
            TMP_OV=$(mktemp)
            trap 'rm -f "$TMP_GEN" "$TMP_OV"' EXIT
            yq -o=json eval '.' release/manifest.generated.yml > "$TMP_GEN"
            yq -o=json eval '.' manifest.overrides.yml > "$TMP_OV"
            jq -s '(.[0].packages // [] | map({(.name): .}) | add // {}) as $gen_by | (.[1].packages // [] | map({(.name): .}) | add // {}) as $ov_by | (.[1].packages // [] | map(.name)) as $ov_names | (.[0].packages // [] | map(.name)) as $gen_names | ($ov_names + ($gen_names | map(select(IN($ov_names[]) | not)))) as $order | {version: (.[1].version // .[0].version), packages: [$order[] | . as $n | (($gen_by[$n]) // {}) + (($ov_by[$n]) // {}) | .name = $n]}' "$TMP_GEN" "$TMP_OV" | yq -P - > release/manifest.yml
          else
            cp release/manifest.generated.yml release/manifest.yml
          fi

          echo "release/manifest.yml" >> release_files.txt

          echo "files<<EOF" >> $GITHUB_OUTPUT
          cat release_files.txt >> $GITHUB_OUTPUT
          echo "EOF" >> $GITHUB_OUTPUT

      - name: Create Release
        uses: softprops/action-gh-release@v1
        with:
          tag_name: ${{ github.ref_name }}
          files: ${{ steps.prepare.outputs.files }}
          token: ${{ secrets.GITHUB_TOKEN }}
