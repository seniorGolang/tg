# GENERATED BY 'T'ool 'G'ateway. DO NOT EDIT.
variables:
  ALPINE_IMAGE: 'alpine:latest'
  GOLANG_IMAGE: 'golang:1.25-alpine'

stages:
  - build
  - deploy

# Для тега v{version} - деплоим все плагины
detect_plugins:
  stage: build
  image: $ALPINE_IMAGE
  before_script:
    - apk add --no-cache findutils jq
  script:
    - |
      # Извлекаем версию из тега (формат v{version})
      case "$CI_COMMIT_TAG" in
        v*)
          PLUGIN_VERSION="${CI_COMMIT_TAG#v}"
          ;;
        *)
          echo "Неверный формат тега: $CI_COMMIT_TAG (ожидается v{version})"
          exit 1
          ;;
      esac
      echo "version=$PLUGIN_VERSION" > version.txt

      # Обнаруживаем все плагины
      PLUGINS=$(find plugins -mindepth 1 -maxdepth 1 -type d -exec basename {} \; | sort)
      JSON_PLUGINS=$(echo "$PLUGINS" | jq -R -s -c 'split("\n") | map(select(length > 0))')
      echo "plugins=$JSON_PLUGINS" > plugins.txt
  artifacts:
    paths:
      - version.txt
      - plugins.txt
    expire_in: 1 hour
  rules:
    - if: $CI_COMMIT_TAG =~ /^v.+$/

build_all:
  stage: build
  image: $GOLANG_IMAGE
  needs:
    - job: detect_plugins
      artifacts: true
  before_script:
    - apk add --no-cache jq
  script:
    - |
      # Извлекаем версию из артефактов
      PLUGIN_VERSION=$(cat version.txt | grep "^version=" | cut -d= -f2-)

      # Получаем список плагинов из артефактов
      PLUGINS_JSON=$(cat plugins.txt | grep "^plugins=" | cut -d= -f2-)

      # Обрабатываем каждый плагин
      for PLUGIN_DIR in $(echo "$PLUGINS_JSON" | jq -r '.[]'); do
        PLUGIN_DIR_PATH="plugins/$PLUGIN_DIR"
        mkdir -p dist

        # Генерируем манифест из кода
        cd "$PLUGIN_DIR_PATH"
        TEMP_MANIFEST="../../dist/temp_${PLUGIN_DIR}.json"
        if ! go run -tags pluginInfo . "$TEMP_MANIFEST" 2>&1; then
          echo "ОШИБКА: не удалось сгенерировать манифест для $PLUGIN_DIR"
          exit 1
        fi

        if [ ! -f "$TEMP_MANIFEST" ]; then
          echo "ОШИБКА: файл манифеста не создан для $PLUGIN_DIR"
          exit 1
        fi

        # Извлекаем имя плагина из сгенерированного манифеста
        PLUGIN_NAME=$(jq -r '.name' "$TEMP_MANIFEST")
        if [ -z "$PLUGIN_NAME" ] || [ "$PLUGIN_NAME" = "null" ]; then
          echo "ОШИБКА: Имя плагина не найдено в сгенерированном манифесте для $PLUGIN_DIR"
          exit 1
        fi

        # Обновляем версию в манифесте
        jq --arg version "$PLUGIN_VERSION" '.version = $version' "$TEMP_MANIFEST" > "../../dist/$PLUGIN_NAME.json"
        rm -f "$TEMP_MANIFEST"

        # Собираем плагин
        echo "Building plugin: $PLUGIN_NAME (directory: $PLUGIN_DIR)"
        cd ../..
        GOOS=wasip1 GOARCH=wasm go build -o "$PLUGIN_DIR_PATH/$PLUGIN_NAME.tgp" -buildmode=c-shared "./$PLUGIN_DIR_PATH"

        # Копируем сгенерированный манифест
        cp "dist/$PLUGIN_NAME.json" "$PLUGIN_DIR_PATH/$PLUGIN_NAME.json"
      done
  artifacts:
    paths:
      - plugins/*/*.tgp
      - plugins/*/*.json
      - dist/*.json
    expire_in: 1 week
  rules:
    - if: $CI_COMMIT_TAG =~ /^v.+$/

deploy_all:
  stage: deploy
  image: $ALPINE_IMAGE
  needs:
    - job: detect_plugins
      artifacts: true
    - job: build_all
      artifacts: true
  before_script:
    - apk add --no-cache curl jq
  script:
    - |
      # Извлекаем версию из артефактов
      PLUGIN_VERSION=$(cat version.txt | grep "^version=" | cut -d= -f2-)

      PLUGINS_JSON=$(cat plugins.txt | grep "^plugins=" | cut -d= -f2-)
      VERSION="$PLUGIN_VERSION"

      mkdir -p "release"

      # Обрабатываем каждый плагин
      for PLUGIN_DIR in $(echo "$PLUGINS_JSON" | jq -r '.[]'); do
        PLUGIN_DIR_PATH="plugins/$PLUGIN_DIR"
        
        # Находим JSON файл в директории плагина (он был скопирован туда в build_all)
        PLUGIN_JSON_SRC=$(find "$PLUGIN_DIR_PATH" -name "*.json" | head -1)
        if [ -z "$PLUGIN_JSON_SRC" ] || [ ! -f "$PLUGIN_JSON_SRC" ]; then
          echo "ОШИБКА: JSON манифест не найден в $PLUGIN_DIR_PATH для плагина $PLUGIN_DIR" >&2
          exit 1
        fi
        
        PLUGIN_NAME=$(jq -r '.name' "$PLUGIN_JSON_SRC")
        if [ -z "$PLUGIN_NAME" ] || [ "$PLUGIN_NAME" = "null" ]; then
          echo "ОШИБКА: Имя плагина не найдено в манифесте для $PLUGIN_DIR" >&2
          exit 1
        fi
        
        # Копируем файлы из артефактов
        for EXT in tgp json; do
          SRC="$PLUGIN_DIR_PATH/$PLUGIN_NAME.$EXT"
          DST="release/$PLUGIN_NAME.$EXT"
          if [ ! -f "$SRC" ]; then
            echo "ОШИБКА: Файл $SRC не найден для плагина $PLUGIN_NAME" >&2
            exit 1
          fi
          cp "$SRC" "$DST"
        done
      done

      # Генерируем YAML манифест
      echo "version: '$VERSION'" > release/manifest.yml
      echo "" >> release/manifest.yml
      echo "packages:" >> release/manifest.yml

      FIRST_PACKAGE=true
      for PLUGIN_DIR in $(echo "$PLUGINS_JSON" | jq -r '.[]'); do
        PLUGIN_DIR_PATH="plugins/$PLUGIN_DIR"
        
        # Находим JSON файл в директории плагина
        PLUGIN_JSON_SRC=$(find "$PLUGIN_DIR_PATH" -name "*.json" | head -1)
        if [ -z "$PLUGIN_JSON_SRC" ] || [ ! -f "$PLUGIN_JSON_SRC" ]; then
          echo "ОШИБКА: JSON манифест не найден в $PLUGIN_DIR_PATH для плагина $PLUGIN_DIR" >&2
          exit 1
        fi
        
        PLUGIN_NAME=$(jq -r '.name' "$PLUGIN_JSON_SRC")
        PLUGIN_DESCR=$(jq -r '.description // ""' "$PLUGIN_JSON_SRC")
        PLUGIN_DEPS=$(jq -r '.dependencies // []' "$PLUGIN_JSON_SRC")
        
        # Вычисляем checksum для tgp файла
        TGP_CHECKSUM=$(sha256sum "release/$PLUGIN_NAME.tgp" | awk '{print $1}')
        
        # Формируем URL для файлов в packages (будут доступны через Release)
        TGP_URL="${CI_API_V4_URL}/projects/${CI_PROJECT_ID}/packages/generic/release/${VERSION}/${PLUGIN_NAME}.tgp"
        
        # Формируем destination пути
        TGP_DEST="plugins/$PLUGIN_DIR/$VERSION/$PLUGIN_NAME.tgp"
        
        # Добавляем пакет в манифест
        if [ "$FIRST_PACKAGE" = "true" ]; then
          FIRST_PACKAGE=false
        else
          echo "" >> release/manifest.yml
        fi
        
        echo "  - name: '$PLUGIN_NAME'" >> release/manifest.yml
        if [ -n "$PLUGIN_DESCR" ] && [ "$PLUGIN_DESCR" != "null" ]; then
          echo "    descr: '$PLUGIN_DESCR'" >> release/manifest.yml
        fi
        # Добавляем зависимости, если они есть
        if [ "$PLUGIN_DEPS" != "[]" ] && [ "$PLUGIN_DEPS" != "null" ]; then
          echo "    dependencies:" >> release/manifest.yml
          echo "$PLUGIN_DEPS" | jq -r '.[]' | while IFS= read -r dep; do
            if [ -n "$dep" ]; then
              echo "      - '$dep'" >> release/manifest.yml
            fi
          done
        fi
        echo "    downloads:" >> release/manifest.yml
        echo "      - url: '$TGP_URL'" >> release/manifest.yml
        echo "    files:" >> release/manifest.yml
        echo "      - file: '$PLUGIN_NAME.tgp'" >> release/manifest.yml
        echo "        destination: '$TGP_DEST'" >> release/manifest.yml
        echo "        checksum: 'sha256:$TGP_CHECKSUM'" >> release/manifest.yml
      done

      # Загружаем файлы через GitLab Generic Packages для получения прямых URL
      echo "Uploading files for Release"
      ASSETS_LINKS="[]"

      for PLUGIN_DIR in $(echo "$PLUGINS_JSON" | jq -r '.[]'); do
        PLUGIN_DIR_PATH="plugins/$PLUGIN_DIR"
        PLUGIN_JSON_SRC=$(find "$PLUGIN_DIR_PATH" -name "*.json" | head -1)
        if [ -f "$PLUGIN_JSON_SRC" ]; then
          PLUGIN_NAME=$(jq -r '.name' "$PLUGIN_JSON_SRC")
          echo "Uploading ${PLUGIN_NAME}.tgp"
          curl -s --header "JOB-TOKEN: $CI_JOB_TOKEN" \
            --upload-file "release/${PLUGIN_NAME}.tgp" \
            "${CI_API_V4_URL}/projects/${CI_PROJECT_ID}/packages/generic/release/${VERSION}/${PLUGIN_NAME}.tgp" > /dev/null
          
          # Формируем URL для файла в packages
          FILE_URL="${CI_API_V4_URL}/projects/${CI_PROJECT_ID}/packages/generic/release/${VERSION}/${PLUGIN_NAME}.tgp"
          ASSETS_LINKS=$(echo "$ASSETS_LINKS" | jq --arg name "${PLUGIN_NAME}.tgp" --arg url "$FILE_URL" '. += [{"name": $name, "url": $url}]')
        fi
      done

      # Загружаем manifest.yml
      echo "Uploading manifest.yml"
      curl -s --header "JOB-TOKEN: $CI_JOB_TOKEN" \
        --upload-file "release/manifest.yml" \
        "${CI_API_V4_URL}/projects/${CI_PROJECT_ID}/packages/generic/release/${VERSION}/manifest.yml" > /dev/null

      FILE_URL="${CI_API_V4_URL}/projects/${CI_PROJECT_ID}/packages/generic/release/${VERSION}/manifest.yml"
      ASSETS_LINKS=$(echo "$ASSETS_LINKS" | jq --arg name "manifest.yml" --arg url "$FILE_URL" '. += [{"name": $name, "url": $url}]')

      # Формируем описание Release
      RELEASE_DESCRIPTION="Release версии $VERSION\n\n## Плагины\n\n"
      for PLUGIN_DIR in $(echo "$PLUGINS_JSON" | jq -r '.[]'); do
        PLUGIN_DIR_PATH="plugins/$PLUGIN_DIR"
        PLUGIN_JSON_SRC=$(find "$PLUGIN_DIR_PATH" -name "*.json" | head -1)
        if [ -f "$PLUGIN_JSON_SRC" ]; then
          PLUGIN_NAME=$(jq -r '.name' "$PLUGIN_JSON_SRC")
          PLUGIN_DESCR=$(jq -r '.description // ""' "$PLUGIN_JSON_SRC")
          RELEASE_DESCRIPTION="${RELEASE_DESCRIPTION}- **$PLUGIN_NAME**"
          if [ -n "$PLUGIN_DESCR" ] && [ "$PLUGIN_DESCR" != "null" ]; then
            RELEASE_DESCRIPTION="${RELEASE_DESCRIPTION}: $PLUGIN_DESCR"
          fi
          RELEASE_DESCRIPTION="${RELEASE_DESCRIPTION}\n"
        fi
      done

      # Создаем Release с прикрепленными файлами
      echo "Creating Release ${CI_COMMIT_TAG}"
      RELEASE_RESPONSE=$(curl -s --request POST \
        --header "JOB-TOKEN: $CI_JOB_TOKEN" \
        --header "Content-Type: application/json" \
        --data "{
          \"name\": \"Release $VERSION\",
          \"tag_name\": \"${CI_COMMIT_TAG}\",
          \"description\": $(echo -n "$RELEASE_DESCRIPTION" | jq -Rs .),
          \"assets\": {
            \"links\": $(echo "$ASSETS_LINKS" | jq -c .)
          }
        }" \
        "${CI_API_V4_URL}/projects/${CI_PROJECT_ID}/releases")

      if echo "$RELEASE_RESPONSE" | jq -e '.message' > /dev/null 2>&1; then
        echo "ОШИБКА при создании Release: $(echo "$RELEASE_RESPONSE" | jq -r '.message')" >&2
        exit 1
      fi

      echo "Release ${CI_COMMIT_TAG} успешно создан"
  rules:
    - if: $CI_COMMIT_TAG =~ /^v.+$/
