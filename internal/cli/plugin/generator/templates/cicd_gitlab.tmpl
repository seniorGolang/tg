detect_plugins:
  stage: build
  image: $ALPINE_IMAGE
  before_script:
    - apk add --no-cache findutils jq
  script:
    - |
      case "$CI_COMMIT_TAG" in
        v*)
          PLUGIN_VERSION="${CI_COMMIT_TAG#v}"
          ;;
        *)
          echo "Неверный формат тега: $CI_COMMIT_TAG (ожидается v{version})"
          exit 1
          ;;
      esac
      echo "version=$PLUGIN_VERSION" > version.txt

      PLUGINS=$(find plugins -mindepth 1 -maxdepth 1 -type d -exec basename {} \; | sort)
      JSON_PLUGINS=$(echo "$PLUGINS" | jq -R -s -c 'split("\n") | map(select(length > 0))')
      echo "plugins=$JSON_PLUGINS" > plugins.txt
  artifacts:
    paths:
      - version.txt
      - plugins.txt
    expire_in: 1 hour
  rules:
    - if: $CI_COMMIT_TAG =~ /^v.+$/

build_all:
  stage: build
  image: $GOLANG_IMAGE
  needs:
